# ══════════════════════════════════════════════════════════════════════════════
#  Mustikatama ERP — Environment Configuration
#  Copy this file to .env and fill in your values.
#  NEVER commit .env to git.
# ══════════════════════════════════════════════════════════════════════════════

# ── App ───────────────────────────────────────────────────────────────────────
APP_PORT=80          # Port to expose on LAN (e.g. 80 = http://192.168.1.50)

# ── Database (local PostgreSQL) ───────────────────────────────────────────────
DB_NAME=erp
DB_USER=erp
DB_PASSWORD=CHANGE_THIS_STRONG_PASSWORD

# ── JWT Auth ──────────────────────────────────────────────────────────────────
JWT_SECRET=CHANGE_THIS_VERY_LONG_RANDOM_SECRET_STRING

# ── Supabase Cloud (OPTIONAL — for sync only) ─────────────────────────────────
# Leave blank to run 100% on-prem with no cloud sync.
# If set, the sync daemon will push changes to Supabase every SYNC_INTERVAL seconds.
SUPABASE_URL=https://YOUR_PROJECT.supabase.co
SUPABASE_KEY=YOUR_SERVICE_ROLE_KEY    # Use service_role key (not anon) for server-side sync

# ── Sync settings ─────────────────────────────────────────────────────────────
SYNC_INTERVAL=300    # How often to sync (seconds). 300 = every 5 minutes.

# ── AI / Claude (OPTIONAL — required for AI features) ────────────────────────
# Get your key at: https://console.anthropic.com/
# Without this key, /api/ai/* endpoints return 503 with { demo: true }.
ANTHROPIC_API_KEY=sk-ant-...
